<Window x:Class="TubaToolbox.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tuba Toolbox" 
        Height="650" Width="1000"
        MinWidth="850" MinHeight="550"
        WindowStartupLocation="CenterScreen"
        Background="#2980B9">
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#2C3E50">
            <StackPanel>
                <Border Background="#1A252F" Padding="12,15">
                    <TextBlock Text="🔧 Tuba Toolbox" FontSize="16" FontWeight="Bold" 
                               Foreground="White" FontFamily="Segoe UI"/>
                </Border>
                
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="categoriesPanel" Margin="0,10,0,0"/>
                </ScrollViewer>

                <TextBlock x:Name="versionText" Text="v2026.05" FontSize="11" Foreground="#7F8C8D" 
                           FontFamily="Segoe UI" HorizontalAlignment="Center"
                           Margin="0,20,0,10"/>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Background="#3498DB">
            <ContentControl x:Name="contentArea" Margin="20,15,15,15"/>
        </Border>
    </Grid>
</Window>